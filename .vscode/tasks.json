{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure (Wii)",
            "type": "shell",
            "command": "/opt/devkitpro/portlibs/wii/bin/powerpc-eabi-cmake -B build -S .",
            "options": {
                "env": {
                    "DEVKITPRO": "/opt/devkitpro",
                    "DEVKITPPC": "/opt/devkitpro/devkitPPC"
                }
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "CMake Build (Wii)",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "CMake Configure (Wii)"
            ],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake Clean (Wii)",
            "type": "shell",
            "command": "rm -rf build",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
