{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure (Wii)",
            "type": "shell",
            "command": "cmake -B build -S . -DCMAKE_TOOLCHAIN_FILE=wii.cmake",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "CMake Build (Wii)",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "CMake Configure (Wii)"
            ],
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake Clean (Wii)",
            "type": "shell",
            "command": "rm -rf build",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
